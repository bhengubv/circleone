c --- J: U+E120-E124 ---
'j' + 'a' > U+E120  c ja
'j' + 'e' > U+E121  c je
'j' + 'i' > U+E122  c ji
'j' + 'o' > U+E123  c jo
'j' + 'u' > U+E124  c ju

c --- C (dental click): U+E140-E144 ---
'c' + 'a' > U+E140  c ca
'c' + 'e' > U+E141  c ce
'c' + 'i' > U+E142  c ci
'c' + 'o' > U+E143  c co
'c' + 'u' > U+E144  c cu

c --- Q (palatal click): U+E160-E164 ---

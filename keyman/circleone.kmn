c CircleOne isiBheqe soHlamvu Keyboard
c Featural syllabary for isiZulu/isiXhosa/isiNdebele
c
c Input is Latin transliteration (consonant+vowel, e.g. 'ba')
c Rendering shows vowel-first (isiBheqe glyph has vowel as outer shape)
c
c PUA codepoints: U+E000-U+E1B2
c Layout: each consonant group at 0x08 or 0x10 boundaries
c         with 5 vowel variants (a=+0, e=+1, i=+2, o=+3, u=+4)
c
c Source of truth: font/one-pua-map.csv

store(&version) '10.0'
store(&name) 'CircleOne isiBheqe'
store(&copyright) '(c) 2026 Mqondisi Bhebhe / The Geek Network (Pty) Ltd'
store(&keyboardversion) '0.1.0'

begin Unicode > use(main)

group(main) using keys

c ============================================================
c PURE VOWELS: U+E000 - U+E004
c ============================================================
+ 'a' > U+E000  c a
+ 'e' > U+E001  c e
+ 'i' > U+E002  c i
+ 'o' > U+E003  c o
+ 'u' > U+E004  c u

c ============================================================
c LONG VOWELS: U+E005 - U+E007
c Double-tap a vowel to get its long form
c ============================================================
U+E000 + 'a' > U+E005  c aa (long a)
U+E001 + 'e' > U+E006  c ee (long e)
U+E002 + 'i' > U+E007  c ii (long i)

c ============================================================
c SYLLABIC NASALS: U+E1B0 - U+E1B2
c Prefix with hyphen to distinguish from CV nasals
c ============================================================
'-' + 'm' > U+E1B0  c syllabic m
'-' + 'n' > U+E1B1  c syllabic n
U+E1B1 + 'g' > U+E1B2  c syllabic ng (typed as -ng)

c ============================================================
c SINGLE-CONSONANT CV SYLLABLES
c Pattern: 'C' + 'V' > U+XXXX
c ============================================================

c ------------------------------------------------------------
c B SYLLABLES: U+E010 - U+E014
c ------------------------------------------------------------
'b' + 'a' > U+E010  c ba
'b' + 'e' > U+E011  c be
'b' + 'i' > U+E012  c bi
'b' + 'o' > U+E013  c bo
'b' + 'u' > U+E014  c bu

c ------------------------------------------------------------
c P SYLLABLES: U+E018 - U+E01C
c ------------------------------------------------------------
'p' + 'a' > U+E018  c pa
'p' + 'e' > U+E019  c pe
'p' + 'i' > U+E01A  c pi
'p' + 'o' > U+E01B  c po
'p' + 'u' > U+E01C  c pu

c ------------------------------------------------------------
c D SYLLABLES: U+E028 - U+E02C
c ------------------------------------------------------------
'd' + 'a' > U+E028  c da
'd' + 'e' > U+E029  c de
'd' + 'i' > U+E02A  c di
'd' + 'o' > U+E02B  c do
'd' + 'u' > U+E02C  c du

c ------------------------------------------------------------
c T SYLLABLES: U+E030 - U+E034
c ------------------------------------------------------------
't' + 'a' > U+E030  c ta
't' + 'e' > U+E031  c te
't' + 'i' > U+E032  c ti
't' + 'o' > U+E033  c to
't' + 'u' > U+E034  c tu

c ------------------------------------------------------------
c G SYLLABLES: U+E040 - U+E044
c ------------------------------------------------------------
'g' + 'a' > U+E040  c ga
'g' + 'e' > U+E041  c ge
'g' + 'i' > U+E042  c gi
'g' + 'o' > U+E043  c go
'g' + 'u' > U+E044  c gu

c ------------------------------------------------------------
c K SYLLABLES: U+E048 - U+E04C
c ------------------------------------------------------------
'k' + 'a' > U+E048  c ka
'k' + 'e' > U+E049  c ke
'k' + 'i' > U+E04A  c ki
'k' + 'o' > U+E04B  c ko
'k' + 'u' > U+E04C  c ku

c ------------------------------------------------------------
c F SYLLABLES: U+E060 - U+E064
c ------------------------------------------------------------
'f' + 'a' > U+E060  c fa
'f' + 'e' > U+E061  c fe
'f' + 'i' > U+E062  c fi
'f' + 'o' > U+E063  c fo
'f' + 'u' > U+E064  c fu

c ------------------------------------------------------------
c V SYLLABLES: U+E068 - U+E06C
c ------------------------------------------------------------
'v' + 'a' > U+E068  c va
'v' + 'e' > U+E069  c ve
'v' + 'i' > U+E06A  c vi
'v' + 'o' > U+E06B  c vo
'v' + 'u' > U+E06C  c vu

c ------------------------------------------------------------
c S SYLLABLES: U+E070 - U+E074
c ------------------------------------------------------------
's' + 'a' > U+E070  c sa
's' + 'e' > U+E071  c se
's' + 'i' > U+E072  c si
's' + 'o' > U+E073  c so
's' + 'u' > U+E074  c su

c ------------------------------------------------------------
c Z SYLLABLES: U+E078 - U+E07C
c ------------------------------------------------------------
'z' + 'a' > U+E078  c za
'z' + 'e' > U+E079  c ze
'z' + 'i' > U+E07A  c zi
'z' + 'o' > U+E07B  c zo
'z' + 'u' > U+E07C  c zu

c ------------------------------------------------------------
c H SYLLABLES: U+E088 - U+E08C
c ------------------------------------------------------------
'h' + 'a' > U+E088  c ha
'h' + 'e' > U+E089  c he
'h' + 'i' > U+E08A  c hi
'h' + 'o' > U+E08B  c ho
'h' + 'u' > U+E08C  c hu

c ------------------------------------------------------------
c M SYLLABLES: U+E0A0 - U+E0A4
c ------------------------------------------------------------
'm' + 'a' > U+E0A0  c ma
'm' + 'e' > U+E0A1  c me
'm' + 'i' > U+E0A2  c mi
'm' + 'o' > U+E0A3  c mo
'm' + 'u' > U+E0A4  c mu

c ------------------------------------------------------------
c N SYLLABLES: U+E0A8 - U+E0AC
c ------------------------------------------------------------
'n' + 'a' > U+E0A8  c na
'n' + 'e' > U+E0A9  c ne
'n' + 'i' > U+E0AA  c ni
'n' + 'o' > U+E0AB  c no
'n' + 'u' > U+E0AC  c nu

c ------------------------------------------------------------
c L SYLLABLES: U+E0C0 - U+E0C4
c ------------------------------------------------------------
'l' + 'a' > U+E0C0  c la
'l' + 'e' > U+E0C1  c le
'l' + 'i' > U+E0C2  c li
'l' + 'o' > U+E0C3  c lo
'l' + 'u' > U+E0C4  c lu

c ------------------------------------------------------------
c R SYLLABLES: U+E0C8 - U+E0CC
c ------------------------------------------------------------
'r' + 'a' > U+E0C8  c ra
'r' + 'e' > U+E0C9  c re
'r' + 'i' > U+E0CA  c ri
'r' + 'o' > U+E0CB  c ro
'r' + 'u' > U+E0CC  c ru

c ------------------------------------------------------------
c W SYLLABLES: U+E0D0 - U+E0D4
c ------------------------------------------------------------
'w' + 'a' > U+E0D0  c wa
'w' + 'e' > U+E0D1  c we
'w' + 'i' > U+E0D2  c wi
'w' + 'o' > U+E0D3  c wo
'w' + 'u' > U+E0D4  c wu

c ------------------------------------------------------------
c Y SYLLABLES: U+E0D8 - U+E0DC
c ------------------------------------------------------------
'y' + 'a' > U+E0D8  c ya
'y' + 'e' > U+E0D9  c ye
'y' + 'i' > U+E0DA  c yi
'y' + 'o' > U+E0DB  c yo
'y' + 'u' > U+E0DC  c yu

c ------------------------------------------------------------
c J SYLLABLES: U+E120 - U+E124
c ------------------------------------------------------------
'j' + 'a' > U+E120  c ja
'j' + 'e' > U+E121  c je
'j' + 'i' > U+E122  c ji
'j' + 'o' > U+E123  c jo
'j' + 'u' > U+E124  c ju

c ------------------------------------------------------------
c C SYLLABLES (dental click): U+E140 - U+E144
c ------------------------------------------------------------
'c' + 'a' > U+E140  c ca
'c' + 'e' > U+E141  c ce
'c' + 'i' > U+E142  c ci
'c' + 'o' > U+E143  c co
'c' + 'u' > U+E144  c cu

c ------------------------------------------------------------
c Q SYLLABLES (palatal click): U+E160 - U+E164
c ------------------------------------------------------------
'q' + 'a' > U+E160  c qa
'q' + 'e' > U+E161  c qe
'q' + 'i' > U+E162  c qi
'q' + 'o' > U+E163  c qo
'q' + 'u' > U+E164  c qu

c ------------------------------------------------------------
c X SYLLABLES (lateral click): U+E180 - U+E184
c ------------------------------------------------------------
'x' + 'a' > U+E180  c xa
'x' + 'e' > U+E181  c xe
'x' + 'i' > U+E182  c xi
'x' + 'o' > U+E183  c xo
'x' + 'u' > U+E184  c xu

c ============================================================
c TWO-CHAR CONSONANT CV SYLLABLES (deadkey-based)
c First char + second char produces a deadkey,
c then deadkey + vowel produces the glyph.
c ============================================================

c ------------------------------------------------------------
c PH: U+E020 - U+E024
c ------------------------------------------------------------
'p' + 'h' > dk(ph)
dk(ph) + 'a' > U+E020  c pha
dk(ph) + 'e' > U+E021  c phe
dk(ph) + 'i' > U+E022  c phi
dk(ph) + 'o' > U+E023  c pho
dk(ph) + 'u' > U+E024  c phu

c ------------------------------------------------------------
c TH: U+E038 - U+E03C
c ------------------------------------------------------------
't' + 'h' > dk(th)
dk(th) + 'a' > U+E038  c tha
dk(th) + 'e' > U+E039  c the
dk(th) + 'i' > U+E03A  c thi
dk(th) + 'o' > U+E03B  c tho
dk(th) + 'u' > U+E03C  c thu

c ------------------------------------------------------------
c KH: U+E050 - U+E054
c ------------------------------------------------------------
'k' + 'h' > dk(kh)
dk(kh) + 'a' > U+E050  c kha
dk(kh) + 'e' > U+E051  c khe
dk(kh) + 'i' > U+E052  c khi
dk(kh) + 'o' > U+E053  c kho
dk(kh) + 'u' > U+E054  c khu

c ------------------------------------------------------------
c SH: U+E080 - U+E084
c ------------------------------------------------------------
's' + 'h' > dk(sh)
dk(sh) + 'a' > U+E080  c sha
dk(sh) + 'e' > U+E081  c she
dk(sh) + 'i' > U+E082  c shi
dk(sh) + 'o' > U+E083  c sho
dk(sh) + 'u' > U+E084  c shu

c ------------------------------------------------------------
c HL: U+E090 - U+E094
c ------------------------------------------------------------
'h' + 'l' > dk(hl)
dk(hl) + 'a' > U+E090  c hla
dk(hl) + 'e' > U+E091  c hle
dk(hl) + 'i' > U+E092  c hli
dk(hl) + 'o' > U+E093  c hlo
dk(hl) + 'u' > U+E094  c hlu

c ------------------------------------------------------------
c DL: U+E098 - U+E09C
c ------------------------------------------------------------
'd' + 'l' > dk(dl)
dk(dl) + 'a' > U+E098  c dla
dk(dl) + 'e' > U+E099  c dle
dk(dl) + 'i' > U+E09A  c dli
dk(dl) + 'o' > U+E09B  c dlo
dk(dl) + 'u' > U+E09C  c dlu

c ------------------------------------------------------------
c NG: U+E0B0 - U+E0B4
c ------------------------------------------------------------
'n' + 'g' > dk(ng)
dk(ng) + 'a' > U+E0B0  c nga
dk(ng) + 'e' > U+E0B1  c nge
dk(ng) + 'i' > U+E0B2  c ngi
dk(ng) + 'o' > U+E0B3  c ngo
dk(ng) + 'u' > U+E0B4  c ngu

c ------------------------------------------------------------
c NY: U+E0B8 - U+E0BC
c ------------------------------------------------------------
'n' + 'y' > dk(ny)
dk(ny) + 'a' > U+E0B8  c nya
dk(ny) + 'e' > U+E0B9  c nye
dk(ny) + 'i' > U+E0BA  c nyi
dk(ny) + 'o' > U+E0BB  c nyo
dk(ny) + 'u' > U+E0BC  c nyu

c ------------------------------------------------------------
c BH: U+E0E0 - U+E0E4
c ------------------------------------------------------------
'b' + 'h' > dk(bh)
dk(bh) + 'a' > U+E0E0  c bha
dk(bh) + 'e' > U+E0E1  c bhe
dk(bh) + 'i' > U+E0E2  c bhi
dk(bh) + 'o' > U+E0E3  c bho
dk(bh) + 'u' > U+E0E4  c bhu

c ------------------------------------------------------------
c MB: U+E0E8 - U+E0EC
c ------------------------------------------------------------
'm' + 'b' > dk(mb)
dk(mb) + 'a' > U+E0E8  c mba
dk(mb) + 'e' > U+E0E9  c mbe
dk(mb) + 'i' > U+E0EA  c mbi
dk(mb) + 'o' > U+E0EB  c mbo
dk(mb) + 'u' > U+E0EC  c mbu

c ------------------------------------------------------------
c ND: U+E0F0 - U+E0F4
c ------------------------------------------------------------
'n' + 'd' > dk(nd)
dk(nd) + 'a' > U+E0F0  c nda
dk(nd) + 'e' > U+E0F1  c nde
dk(nd) + 'i' > U+E0F2  c ndi
dk(nd) + 'o' > U+E0F3  c ndo
dk(nd) + 'u' > U+E0F4  c ndu

c ------------------------------------------------------------
c NT: U+E0F8 - U+E0FC
c ------------------------------------------------------------
'n' + 't' > dk(nt)
dk(nt) + 'a' > U+E0F8  c nta
dk(nt) + 'e' > U+E0F9  c nte
dk(nt) + 'i' > U+E0FA  c nti
dk(nt) + 'o' > U+E0FB  c nto
dk(nt) + 'u' > U+E0FC  c ntu

c ------------------------------------------------------------
c NK: U+E100 - U+E104
c ------------------------------------------------------------
'n' + 'k' > dk(nk)
dk(nk) + 'a' > U+E100  c nka
dk(nk) + 'e' > U+E101  c nke
dk(nk) + 'i' > U+E102  c nki
dk(nk) + 'o' > U+E103  c nko
dk(nk) + 'u' > U+E104  c nku

c ------------------------------------------------------------
c NJ: U+E108 - U+E10C
c ------------------------------------------------------------
'n' + 'j' > dk(nj)
dk(nj) + 'a' > U+E108  c nja
dk(nj) + 'e' > U+E109  c nje
dk(nj) + 'i' > U+E10A  c nji
dk(nj) + 'o' > U+E10B  c njo
dk(nj) + 'u' > U+E10C  c nju

c ------------------------------------------------------------
c CH: U+E148 - U+E14C
c ------------------------------------------------------------
'c' + 'h' > dk(ch)
dk(ch) + 'a' > U+E148  c cha
dk(ch) + 'e' > U+E149  c che
dk(ch) + 'i' > U+E14A  c chi
dk(ch) + 'o' > U+E14B  c cho
dk(ch) + 'u' > U+E14C  c chu

c ------------------------------------------------------------
c GC: U+E150 - U+E154
c ------------------------------------------------------------
'g' + 'c' > dk(gc)
dk(gc) + 'a' > U+E150  c gca
dk(gc) + 'e' > U+E151  c gce
dk(gc) + 'i' > U+E152  c gci
dk(gc) + 'o' > U+E153  c gco
dk(gc) + 'u' > U+E154  c gcu

c ------------------------------------------------------------
c NC: U+E158 - U+E15C
c ------------------------------------------------------------
'n' + 'c' > dk(nc)
dk(nc) + 'a' > U+E158  c nca
dk(nc) + 'e' > U+E159  c nce
dk(nc) + 'i' > U+E15A  c nci
dk(nc) + 'o' > U+E15B  c nco
dk(nc) + 'u' > U+E15C  c ncu

c ------------------------------------------------------------
c QH: U+E168 - U+E16C
c ------------------------------------------------------------
'q' + 'h' > dk(qh)
dk(qh) + 'a' > U+E168  c qha
dk(qh) + 'e' > U+E169  c qhe
dk(qh) + 'i' > U+E16A  c qhi
dk(qh) + 'o' > U+E16B  c qho
dk(qh) + 'u' > U+E16C  c qhu

c ------------------------------------------------------------
c GQ: U+E170 - U+E174
c ------------------------------------------------------------
'g' + 'q' > dk(gq)
dk(gq) + 'a' > U+E170  c gqa
dk(gq) + 'e' > U+E171  c gqe
dk(gq) + 'i' > U+E172  c gqi
dk(gq) + 'o' > U+E173  c gqo
dk(gq) + 'u' > U+E174  c gqu

c ------------------------------------------------------------
c NQ: U+E178 - U+E17C
c ------------------------------------------------------------
'n' + 'q' > dk(nq)
dk(nq) + 'a' > U+E178  c nqa
dk(nq) + 'e' > U+E179  c nqe
dk(nq) + 'i' > U+E17A  c nqi
dk(nq) + 'o' > U+E17B  c nqo
dk(nq) + 'u' > U+E17C  c nqu

c ------------------------------------------------------------
c XH: U+E188 - U+E18C
c ------------------------------------------------------------
'x' + 'h' > dk(xh)
dk(xh) + 'a' > U+E188  c xha
dk(xh) + 'e' > U+E189  c xhe
dk(xh) + 'i' > U+E18A  c xhi
dk(xh) + 'o' > U+E18B  c xho
dk(xh) + 'u' > U+E18C  c xhu

c ------------------------------------------------------------
c GX: U+E190 - U+E194
c ------------------------------------------------------------
'g' + 'x' > dk(gx)
dk(gx) + 'a' > U+E190  c gxa
dk(gx) + 'e' > U+E191  c gxe
dk(gx) + 'i' > U+E192  c gxi
dk(gx) + 'o' > U+E193  c gxo
dk(gx) + 'u' > U+E194  c gxu

c ------------------------------------------------------------
c NX: U+E198 - U+E19C
c ------------------------------------------------------------
'n' + 'x' > dk(nx)
dk(nx) + 'a' > U+E198  c nxa
dk(nx) + 'e' > U+E199  c nxe
dk(nx) + 'i' > U+E19A  c nxi
dk(nx) + 'o' > U+E19B  c nxo
dk(nx) + 'u' > U+E19C  c nxu

c ============================================================
c THREE-CHAR CONSONANT: TSH (chained deadkeys)
c t -> s produces dk(ts), dk(ts) + h produces dk(tsh)
c U+E128 - U+E12C
c ============================================================
't' + 's' > dk(ts)
dk(ts) + 'h' > dk(tsh)
dk(tsh) + 'a' > U+E128  c tsha
dk(tsh) + 'e' > U+E129  c tshe
dk(tsh) + 'i' > U+E12A  c tshi
dk(tsh) + 'o' > U+E12B  c tsho
dk(tsh) + 'u' > U+E12C  c tshu

c ============================================================
c FOUR-CHAR CONSONANT: NTSH (chained deadkeys)
c n -> t produces dk(nt), dk(nt) + s produces dk(nts),
c dk(nts) + h produces dk(ntsh)
c U+E110 - U+E114
c ============================================================
dk(nt) + 's' > dk(nts)
dk(nts) + 'h' > dk(ntsh)
dk(ntsh) + 'a' > U+E110  c ntsha
dk(ntsh) + 'e' > U+E111  c ntshe
dk(ntsh) + 'i' > U+E112  c ntshi
dk(ntsh) + 'o' > U+E113  c ntsho
dk(ntsh) + 'u' > U+E114  c ntshu

c ============================================================
c END OF KEYBOARD DEFINITION
c ============================================================
c
c PUA ALLOCATION SUMMARY (vowel offset: a=+0, e=+1, i=+2, o=+3, u=+4):
c
c   U+E000-E004  Pure vowels (a, e, i, o, u)
c   U+E005-E007  Long vowels (aa, ee, ii)
c
c   U+E010-E014  b + vowels
c   U+E018-E01C  p + vowels
c   U+E020-E024  ph + vowels
c   U+E028-E02C  d + vowels
c   U+E030-E034  t + vowels
c   U+E038-E03C  th + vowels
c   U+E040-E044  g + vowels
c   U+E048-E04C  k + vowels
c   U+E050-E054  kh + vowels
c   U+E060-E064  f + vowels
c   U+E068-E06C  v + vowels
c   U+E070-E074  s + vowels
c   U+E078-E07C  z + vowels
c   U+E080-E084  sh + vowels
c   U+E088-E08C  h + vowels
c   U+E090-E094  hl + vowels
c   U+E098-E09C  dl + vowels
c   U+E0A0-E0A4  m + vowels
c   U+E0A8-E0AC  n + vowels
c   U+E0B0-E0B4  ng + vowels
c   U+E0B8-E0BC  ny + vowels
c   U+E0C0-E0C4  l + vowels
c   U+E0C8-E0CC  r + vowels
c   U+E0D0-E0D4  w + vowels
c   U+E0D8-E0DC  y + vowels
c   U+E0E0-E0E4  bh + vowels
c   U+E0E8-E0EC  mb + vowels
c   U+E0F0-E0F4  nd + vowels
c   U+E0F8-E0FC  nt + vowels
c   U+E100-E104  nk + vowels
c   U+E108-E10C  nj + vowels
c   U+E110-E114  ntsh + vowels
c   U+E120-E124  j + vowels
c   U+E128-E12C  tsh + vowels
c   U+E140-E144  c (dental click) + vowels
c   U+E148-E14C  ch + vowels
c   U+E150-E154  gc + vowels
c   U+E158-E15C  nc + vowels
c   U+E160-E164  q (palatal click) + vowels
c   U+E168-E16C  qh + vowels
c   U+E170-E174  gq + vowels
c   U+E178-E17C  nq + vowels
c   U+E180-E184  x (lateral click) + vowels
c   U+E188-E18C  xh + vowels
c   U+E190-E194  gx + vowels
c   U+E198-E19C  nx + vowels
c   U+E1B0-E1B2  Syllabic nasals (m, n, ng)
c
c ============================================================

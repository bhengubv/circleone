c CircleOne isiBheqe soHlamvu Keyboard
c Featural syllabary for isiZulu/isiXhosa/isiNdebele
c
c Input is Latin transliteration (consonant+vowel, e.g. 'ba')
c Rendering shows vowel-first (isiBheqe glyph has vowel as outer shape)
c
c PUA codepoints: U+E000-U+E344
c Layout: each consonant group at 0x08 or 0x10 boundaries
c         with 5 vowel variants (a=+0, e=+1, i=+2, o=+3, u=+4)
c
c Source of truth: font/one-pua-map.csv

store(&version) '10.0'
store(&name) 'CircleOne isiBheqe'
store(&copyright) '(c) 2026 The Other Bhengu (Pty) Ltd t/a The Geek.'
store(&keyboardversion) '0.1.0'

begin Unicode > use(main)

group(main) using keys

c ============================================================
c PURE VOWELS: U+E000 - U+E004
c ============================================================
+ 'a' > U+E000  c a
+ 'e' > U+E001  c e
+ 'i' > U+E002  c i
+ 'o' > U+E003  c o
+ 'u' > U+E004  c u

c ============================================================
c LONG VOWELS: U+E005 - U+E007
c Double-tap a vowel to get its long form
c ============================================================
U+E000 + 'a' > U+E005  c aa (long a)
U+E001 + 'e' > U+E006  c ee (long e)
U+E002 + 'i' > U+E007  c ii (long i)

c ============================================================
c SYLLABIC NASALS: U+E1B0 - U+E1B2
c Prefix with hyphen to distinguish from CV nasals
c ============================================================
'-' + 'm' > U+E1B0  c syllabic m
'-' + 'n' > U+E1B1  c syllabic n
U+E1B1 + 'g' > U+E1B2  c syllabic ng (typed as -ng)

c ============================================================
c SINGLE-CONSONANT CV SYLLABLES
c Pattern: 'C' + 'V' > U+XXXX
c ============================================================

c --- B: U+E010-E014 ---
'b' + 'a' > U+E010  c ba
'b' + 'e' > U+E011  c be
'b' + 'i' > U+E012  c bi
'b' + 'o' > U+E013  c bo
'b' + 'u' > U+E014  c bu

c --- P: U+E018-E01C ---
'p' + 'a' > U+E018  c pa
'p' + 'e' > U+E019  c pe
'p' + 'i' > U+E01A  c pi
'p' + 'o' > U+E01B  c po
'p' + 'u' > U+E01C  c pu

c --- D: U+E028-E02C ---
'd' + 'a' > U+E028  c da
'd' + 'e' > U+E029  c de
'd' + 'i' > U+E02A  c di
'd' + 'o' > U+E02B  c do
'd' + 'u' > U+E02C  c du

c --- T: U+E030-E034 ---
't' + 'a' > U+E030  c ta
't' + 'e' > U+E031  c te
't' + 'i' > U+E032  c ti
't' + 'o' > U+E033  c to
't' + 'u' > U+E034  c tu

c --- G: U+E040-E044 ---
'g' + 'a' > U+E040  c ga
'g' + 'e' > U+E041  c ge
'g' + 'i' > U+E042  c gi
'g' + 'o' > U+E043  c go
'g' + 'u' > U+E044  c gu

c --- K: U+E048-E04C ---
'k' + 'a' > U+E048  c ka
'k' + 'e' > U+E049  c ke
'k' + 'i' > U+E04A  c ki
'k' + 'o' > U+E04B  c ko
'k' + 'u' > U+E04C  c ku

c --- F: U+E060-E064 ---
'f' + 'a' > U+E060  c fa
'f' + 'e' > U+E061  c fe
'f' + 'i' > U+E062  c fi
'f' + 'o' > U+E063  c fo
'f' + 'u' > U+E064  c fu


'x' + 'e' > U+E181  c xe
'x' + 'i' > U+E182  c xi
'x' + 'o' > U+E183  c xo
'x' + 'u' > U+E184  c xu

c ============================================================
c TWO-CHAR CONSONANT CV SYLLABLES (deadkey-based)
c First char + second char produces a deadkey,
c then deadkey + vowel produces the glyph.
c ============================================================

c --- PH: U+E020-E024 ---
'p' + 'h' > dk(ph)
dk(ph) + 'a' > U+E020  c pha
dk(ph) + 'e' > U+E021  c phe
dk(ph) + 'i' > U+E022  c phi
dk(ph) + 'o' > U+E023  c pho
dk(ph) + 'u' > U+E024  c phu

c --- TH: U+E038-E03C ---
't' + 'h' > dk(th)

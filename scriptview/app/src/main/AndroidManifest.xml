<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="org.ofrp.scriptview">

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="35" />

    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <!-- ScriptView Accessibility Service -->
        <service
            android:name="org.ofrp.scriptview.ScriptViewService"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/scriptview_config" />
        </service>

        <!-- Enable Guide Activity (MAIN/LAUNCHER) -->
        <activity
            android:name="org.ofrp.scriptview.EnableGuideActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ScriptView Test Activity -->
        <activity
            android:name="org.ofrp.scriptview.ScriptViewTestActivity"
            android:exported="true" />

    </application>

</manifest>
